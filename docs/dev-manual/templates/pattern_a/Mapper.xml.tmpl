<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.platform.v3.core.__domain-kebab__.mapper.__DomainPascal__Mapper">

  <select id="selectList" resultType="map">
    SELECT
      __domain_snake___id AS id,
      title,
      created_by,
      created_at
    FROM platform_v3.__dm_table_prefix__main
    <where>
      <if test="keyword != null and keyword != ''">
        AND title ILIKE '%' || #{keyword} || '%'
      </if>
    </where>
    ORDER BY created_at DESC
    LIMIT 100
  </select>

  <select id="selectDetail" resultType="map">
    SELECT * FROM platform_v3.__dm_table_prefix__main WHERE __domain_snake___id = #{id}
  </select>

  <insert id="insert__DomainPascal__" parameterType="map">
    INSERT INTO platform_v3.__dm_table_prefix__main
      (__domain_snake___id, title, content, created_by, created_at)
    VALUES
      (#{id}, #{title}, #{content}, #{createdBy}, CURRENT_TIMESTAMP)
  </insert>

  <update id="update__DomainPascal__" parameterType="map">
    UPDATE platform_v3.__dm_table_prefix__main
    SET title = #{title}, content = #{content}, updated_at = CURRENT_TIMESTAMP
    WHERE __domain_snake___id = #{id}
  </update>

  <delete id="delete__DomainPascal__">
    DELETE FROM platform_v3.__dm_table_prefix__main WHERE __domain_snake___id = #{id}
  </delete>

</mapper>
