{
  "realm": "openplatform-v3",
  "enabled": true,
  "displayName": "openplatform v3 통합 그룹웨어",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "ROLE_USER", "description": "일반 사용자" },
      { "name": "ROLE_APPROVER", "description": "결재자" },
      { "name": "ROLE_MANAGER", "description": "부서장" },
      { "name": "ROLE_ADMIN", "description": "시스템 관리자" }
    ]
  },
  "clients": [
    {
      "clientId": "v3-ui",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "rootUrl": "http://localhost:25174",
      "redirectUris": ["http://localhost:25174/*", "http://localhost:19173/*"],
      "webOrigins": ["http://localhost:25174", "http://localhost:19173"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:25174/*##http://localhost:19173/*"
      }
    },
    {
      "clientId": "v3-backend-core",
      "enabled": true,
      "bearerOnly": true
    },
    {
      "clientId": "v3-backend-bff",
      "enabled": true,
      "bearerOnly": true
    },
    {
      "clientId": "mattermost",
      "enabled": true,
      "publicClient": false,
      "secret": "CHANGE_ME_KEYCLOAK_CLIENT_SECRET",
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:19065/*"],
      "webOrigins": ["http://localhost:19065"]
    },
    {
      "clientId": "wiki-js",
      "enabled": true,
      "publicClient": false,
      "secret": "CHANGE_ME_WIKIJS_SECRET",
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:19001/*"]
    },
    {
      "clientId": "livekit",
      "enabled": true,
      "bearerOnly": true
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@v3.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "realmRoles": ["ROLE_ADMIN", "ROLE_USER"]
    },
    {
      "username": "user1",
      "enabled": true,
      "email": "user1@v3.local",
      "firstName": "사용자",
      "lastName": "일",
      "credentials": [{ "type": "password", "value": "user1", "temporary": false }],
      "realmRoles": ["ROLE_USER", "ROLE_APPROVER"]
    }
  ]
}
